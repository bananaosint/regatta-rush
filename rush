<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Regatta Rush - High Seas Simulation</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #0f172a;
            font-family: 'Georgia', serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }
        #gameContainer {
            position: relative;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
            width: 800px;
            height: 350px;
            background: linear-gradient(to bottom, #0c4a6e, #0284c7);
        }
        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }
        #gameContainer:fullscreen {
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        #gameContainer:fullscreen canvas {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
        .ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: rgba(15, 23, 42, 0.85);
            color: #f8fafc;
            z-index: 10;
            backdrop-filter: blur(4px);
        }
        h1 {
            margin-top: 0;
            font-size: 38px;
            letter-spacing: 4px;
            color: #f1f5f9;
            text-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        button {
            padding: 10px 32px;
            font-size: 16px;
            background: #0369a1;
            color: #f8fafc;
            border: 1px solid #0284c7;
            cursor: pointer;
            font-weight: bold;
            letter-spacing: 1px;
            transition: all 0.2s;
            margin: 10px;
        }
        button:hover {
            background: #0284c7;
            box-shadow: 0 0 15px rgba(2, 132, 199, 0.6);
        }
        .shop-container {
            background: rgba(30, 41, 59, 0.9);
            padding: 20px;
            border: 1px solid #334155;
            margin-top: 15px;
            width: 320px;
            text-align: center;
        }
        .shop-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 10px 0;
            font-size: 14px;
            color: #cbd5e1;
        }
        .shop-btn {
            padding: 4px 12px;
            font-size: 12px;
            margin: 0;
            background: #059669;
            border: 1px solid #10b981;
        }
        .shop-btn:hover { background: #10b981; }
        .hidden { display: none !important; }
        
        #stats {
            position: absolute;
            top: 15px;
            left: 20px;
            font-size: 14px;
            letter-spacing: 1px;
            color: #e2e8f0;
            pointer-events: none;
            z-index: 5;
            text-shadow: 0 2px 4px rgba(0,0,0,0.8);
        }
        #fullscreenBtn {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 12px;
            padding: 5px 14px;
            z-index: 15;
            background: #1e293b;
            border: 1px solid #475569;
            margin: 0;
        }
    </style>
</head>
<body>

<div id="gameContainer">
    <div id="stats">Shells Found: <span id="shellCount">0</span></div>
    <button id="fullscreenBtn">⚓ Fullscreen</button>
    
    <div id="uiScreen" class="ui-layer">
        <h1 id="menuTitle">REGATTA RUSH</h1>
        <p id="menuSubtitle" style="color:#94a3b8;">Engage throttle with Spacebar or Up Arrow to clear rolling crests.</p>
        <button id="startBtn">BEGIN VOYAGE</button>
        
        <div class="shop-container">
            <h3 style="margin-top:0; color:#f1f5f9;">Harbor Upgrades (Shells: <span id="shopShells">0</span>)</h3>
            <div class="shop-item">
                <span>🐚 Double Yield (<span id="costShell">10</span> sh)</span>
                <button class="shop-btn" id="buyShellUpgrade">Upgrade</button>
            </div>
            <div class="shop-item">
                <span>⛵ Mast Height Boost (<span id="costJump">15</span> sh)</span>
                <button class="shop-btn" id="buyJumpUpgrade">Upgrade</button>
            </div>
        </div>
    </div>

    <canvas id="gameCanvas" width="800" height="350"></canvas>
</div>

<script>
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const gameContainer = document.getElementById('gameContainer');
const fullscreenBtn = document.getElementById('fullscreenBtn');

const uiScreen = document.getElementById('uiScreen');
const menuTitle = document.getElementById('menuTitle');
const menuSubtitle = document.getElementById('menuSubtitle');
const startBtn = document.getElementById('startBtn');
const shellCountDisplay = document.getElementById('shellCount');
const shopShellsDisplay = document.getElementById('shopShells');
const buyShellUpgradeBtn = document.getElementById('buyShellUpgrade');
const buyJumpUpgradeBtn = document.getElementById('buyJumpUpgrade');

// Realistic Physics Values
let gameActive = false;
let score = 0;
let savedShells = parseInt(localStorage.getItem('beach_shells')) || 0;
let upgradeShellLevel = parseInt(localStorage.getItem('up_shell')) || 1; 
let upgradeJumpLevel = parseInt(localStorage.getItem('up_jump')) || 0; 

let gameSpeed = 6;
const baseSpeed = 6;
let gravity = 0.55; 
let obstacles = [];
let items = [];
let spawnTimer = 0;
const waterLine = 240;

const boat = {
    x: 90,
    y: waterLine - 40,
    width: 60,
    height: 55,
    vy: 0,
    jumpForce: -11,
    isGrounded: false,
    hasShield: false,
    speedBoostTimer: 0,
    angle: 0,
    
    jump() {
        if (this.isGrounded) {
            this.vy = this.jumpForce;
            this.isGrounded = false;
        }
    },
    
    update() {
        if (this.speedBoostTimer > 0) {
            this.speedBoostTimer--;
            score += 2.5; 
        } else {
            score += 1;
        }

        this.vy += gravity;
        this.y += this.vy;

        // Dynamic pitch rotation based on vertical movement velocity
        this.angle = this.vy * 0.03;

        if (this.y >= waterLine - 40) {
            this.y = waterLine - 40;
            this.vy = 0;
            this.isGrounded = true;
            this.angle = Math.sin(score * 0.1) * 0.02; // Small natural water rocking simulation
        }
    },

    draw() {
        ctx.save();
        ctx.translate(this.x + this.width / 2, this.y + this.height / 2);
        ctx.rotate(this.angle);

        // Powerup Effects (Subtle realistic wind distortion/sheen)
        if (this.speedBoostTimer > 0) {
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.25)';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(0, 0, 42, 0, Math.PI * 2);
            ctx.stroke();
        }
        if (this.hasShield) {
            ctx.strokeStyle = 'rgba(224, 242, 254, 0.4)';
            ctx.lineWidth = 3;
            ctx.beginPath();
            ctx.arc(0, 0, 38, 0, Math.PI * 2);
            ctx.stroke();
        }

        // Realistic Hull
        ctx.fillStyle = '#1e1b4b'; // Deep navy hull
        ctx.beginPath();
        ctx.moveTo(-25, 5);
        ctx.lineTo(25, 5);
        ctx.quadraticCurveTo(28, 18, 20, 18);
        ctx.lineTo(-20, 18);
        ctx.quadraticCurveTo(-26, 18, -25, 5);
        ctx.closePath();
        ctx.fill();

        // Hull Trim line
        ctx.strokeStyle = '#b91c1c'; 
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(-24, 7);
        ctx.lineTo(24, 7);
        ctx.stroke();

        // Rigid Mast
        ctx.fillStyle = '#475569';
        ctx.fillRect(-2, -35, 3, 40);

        // Canvas Sail (With textured gradients and light shadow mapping)
        let sailGrad = ctx.createLinearGradient(-15, -30, 20, 0);
        sailGrad.addColorStop(0, '#f8fafc');
        sailGrad.addColorStop(1, '#cbd5e1');
        ctx.fillStyle = sailGrad;
        ctx.beginPath();
        ctx.moveTo(1, -34);
        ctx.bezierCurveTo(18, -20, 15, -5, 2, -2);
        ctx.lineTo(1, -2);
        ctx.closePath();
        ctx.fill();

        ctx.restore();
    }
};

class Obstacle {
    constructor(type) {
        this.x = canvas.width;
        this.type = type; // 'barrel' or 'wave'
        this.width = type === 'barrel' ? 26 : 45;
        this.height = type === 'barrel' ? 38 : 55; // Waves can spawn significantly higher now
        if (type === 'wave' && Math.random() > 0.6) this.height += 15; // Mega Crests
        this.y = waterLine - this.height + 10;
    }
    update() {
        this.x -= (boat.speedBoostTimer > 0) ? gameSpeed * 1.6 : gameSpeed;
    }
    draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        
        if (this.type === 'barrel') {
            // Weathered Flotsam Shipping Barrel
            let barrelGrad = ctx.createLinearGradient(0, 0, this.width, 0);
            barrelGrad.addColorStop(0, '#7c2d12');
            barrelGrad.addColorStop(0.5, '#ea580c');
            barrelGrad.addColorStop(1, '#431407');
            ctx.fillStyle = barrelGrad;
            ctx.fillRect(0, 0, this.width, this.height);
            
            // Iron Bands
            ctx.fillStyle = '#475569';
            ctx.fillRect(0, 6, this.width, 3);
            ctx.fillRect(0, this.height - 9, this.width, 3);
        } else {
            // Realistic Translucent Breaking Wave
            let waveGrad = ctx.createLinearGradient(0, 0, 0, this.height);
            waveGrad.addColorStop(0, 'rgba(255, 255, 255, 0.9)'); // White foam crest
            waveGrad.addColorStop(0.2, '#0284c7');
            waveGrad.addColorStop(1, '#0c4a6e');
            ctx.fillStyle = waveGrad;
            
            ctx.beginPath();
            ctx.moveTo(0, this.height);
            ctx.bezierCurveTo(this.width * 0.2, 0, this.width * 0.6, 5, this.width, this.height);
            ctx.closePath();
            ctx.fill();
        }
        ctx.restore();
    }
}

class Collectable {
    constructor(type) {
        this.x = canvas.width;
        this.type = type;
        this.width = 24;
        this.height = 24;
        this.y = waterLine - 100 - Math.random() * 80;
    }
    update() {
        this.x -= (boat.speedBoostTimer > 0) ? gameSpeed * 1.6 : gameSpeed;
    }
    draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        
        if (this.type === 'shell') {
            ctx.fillStyle = '#fed7aa';
            ctx.beginPath();
            ctx.ellipse(12, 12, 10, 12, Math.PI/4, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = '#f97316';
            ctx.lineWidth = 0.5;
            ctx.stroke();
        } else if (this.type === 'shield') {
            // Spec Life Presever Ring
            ctx.fillStyle = '#dc2626';
            ctx.beginPath(); ctx.arc(12, 12, 11, 0, Math.PI*2); ctx.fill();
            ctx.fillStyle = '#f8fafc';
            ctx.beginPath(); ctx.arc(12, 12, 6, 0, Math.PI*2); ctx.fill();
            // Retaining line crosses
            ctx.fillStyle = '#dc2626';
            ctx.fillRect(10, 0, 4, 24);
            ctx.fillRect(0, 10, 24, 4);
            ctx.fillStyle = '#f8fafc';
            ctx.beginPath(); ctx.arc(12, 12, 5, 0, Math.PI*2); ctx.fill();
        } else if (this.type === 'speed') {
            // Squall Wind Lines
            ctx.strokeStyle = '#e2e8f0';
            ctx.lineWidth = 2.5;
            ctx.beginPath();
            ctx.moveTo(2, 6); ctx.lineTo(22, 6);
            ctx.moveTo(6, 12); ctx.lineTo(18, 12);
            ctx.moveTo(0, 18); ctx.lineTo(14, 18);
            ctx.stroke();
        }
        ctx.restore();
    }
}

function drawEnvironment() {
    // Atmospheric Sky Gradient (Sunset/Storm transition)
    let skyGrad = ctx.createLinearGradient(0, 0, 0, waterLine);
    skyGrad.addColorStop(0, '#0f172a');
    skyGrad.addColorStop(0.6, '#1e3a8a');
    skyGrad.addColorStop(1, '#3b82f6');
    ctx.fillStyle = skyGrad;
    ctx.fillRect(0, 0, canvas.width, waterLine);

    // Dynamic Distant Ocean Slicks
    ctx.fillStyle = '#1d4ed8';
    ctx.fillRect(0, waterLine - 25, canvas.width, 25);

    // Deep Active Sea Foreground
    let oceanGrad = ctx.createLinearGradient(0, waterLine, 0, canvas.height);
    oceanGrad.addColorStop(0, '#0369a1');
    oceanGrad.addColorStop(0.3, '#075985');
    oceanGrad.addColorStop(1, '#0c4a6e');
    ctx.fillStyle = oceanGrad;
    ctx.fillRect(0, waterLine, canvas.width, 50);

    // Coast Shoreline / Deep Wet Sand Bed
    let sandGrad = ctx.createLinearGradient(0, waterLine+50, 0, canvas.height);
    sandGrad.addColorStop(0, '#7c2d12');
    sandGrad.addColorStop(0.1, '#a16207');
    sandGrad.addColorStop(1, '#78350f');
    ctx.fillStyle = sandGrad;
    ctx.fillRect(0, waterLine + 50, canvas.width, canvas.height - (waterLine + 50));

    // Moving white shoreline water foam strings
    ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
    ctx.fillRect((score * -2) % canvas.width, waterLine + 48, 300, 2);
    ctx.fillRect(((score * -2) + 450) % canvas.width, waterLine + 49, 200, 1.5);
}

function checkCollision(rect1, rect2) {
    // Tightened hitboxes slightly for realistic precise clearances
    return rect1.x + 6 < rect2.x + rect2.width &&
           rect1.x + rect1.width - 6 > rect2.x &&
           rect1.y + 4 < rect2.y + rect2.height &&
           rect1.y + rect1.height - 2 > rect2.y;
}

function spawnManager() {
    spawnTimer++;
    // HARDER: Substantially reduced minimum buffers between threats
    let targetSpawnTime = Math.max(22, 65 - Math.floor(score / 400));
    
    if (spawnTimer > targetSpawnTime) {
        if (Math.random() < 0.72) { // Higher relative spawn weighting
            let type = Math.random() > 0.45 ? 'wave' : 'barrel';
            obstacles.push(new Obstacle(type));
        } else {
            let rand = Math.random();
            let type = 'shell';
            if (rand > 0.88) type = 'speed';
            else if (rand > 0.72) type = 'shield';
            items.push(new Collectable(type));
        }
        spawnTimer = 0;
    }
}

function updateGame() {
    if (!gameActive) return;

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    drawEnvironment();
    boat.update();
    boat.draw();

    spawnManager();

    // HARDER: Scaling now scales exponentially over time, uncapped!
    gameSpeed = baseSpeed + Math.pow(score, 0.52) * 0.22;

    for (let i = obstacles.length - 1; i >= 0; i--) {
        obstacles[i].update();
        obstacles[i].draw();

        if (checkCollision(boat, obstacles[i])) {
            if (boat.speedBoostTimer > 0) {
                obstacles.splice(i, 1);
                score += 200;
            } else if (boat.hasShield) {
                boat.hasShield = false;
                obstacles.splice(i, 1);
            } else {
                gameOver();
                return;
            }
            continue;
        }
        if (obstacles[i].x < -60) obstacles.splice(i, 1);
    }

    for (let i = items.length - 1; i >= 0; i--) {
        items[i].update();
        items[i].draw();

        if (checkCollision(boat, items[i])) {
            if (items[i].type === 'shell') {
                savedShells += upgradeShellLevel;
                localStorage.setItem('beach_shells', savedShells);
            } else if (items[i].type === 'shield') {
                boat.hasShield = true;
            } else if (items[i].type === 'speed') {
                boat.speedBoostTimer = 130; 
            }
            items.splice(i, 1);
            continue;
        }
        if (items[i].x < -60) items.splice(i, 1);
    }

    shellCountDisplay.innerText = savedShells;
    ctx.fillStyle = '#f1f5f9';
    ctx.font = '13px monospace';
    ctx.fillText(`LOGGED DISTANCE: ${Math.floor(score)}nm`, canvas.width - 210, 26);
    ctx.fillText(`VELOCITY: ${(gameSpeed*3).toFixed(1)} KN`, canvas.width - 210, 44);

    requestAnimationFrame(updateGame);
}

function startGame() {
    uiScreen.classList.add('hidden');
    gameActive = true;
    score = 0;
    gameSpeed = baseSpeed;
    spawnTimer = 0;
    obstacles = [];
    items = [];
    boat.y = waterLine - 40;
    boat.vy = 0;
    boat.hasShield = false;
    boat.speedBoostTimer = 0;
    // Applied Upgrades
    boat.jumpForce = -11 - (upgradeJumpLevel * 0.7);
    
    updateGame();
}

function gameOver() {
    gameActive = false;
    menuTitle.innerText = "VESSEL CAPSIZED";
    menuSubtitle.innerText = `Log entry recorded at ${Math.floor(score)} nautical miles.`;
    startBtn.innerText = "RE-LAUNCH VESSEL";
    updateShopUI();
    uiScreen.classList.remove('hidden');
}

function updateShopUI() {
    shopShellsDisplay.innerText = savedShells;
    shellCountDisplay.innerText = savedShells;
    
    let shellCost = upgradeShellLevel * 10;
    let jumpCost = (upgradeJumpLevel + 1) * 15;
    
    document.getElementById('costShell').innerText = shellCost;
    document.getElementById('costJump').innerText = jumpCost;
}

fullscreenBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!document.fullscreenElement) {
        if (gameContainer.requestFullscreen) {
            gameContainer.requestFullscreen();
        } else if (gameContainer.webkitRequestFullscreen) {
            gameContainer.webkitRequestFullscreen();
        }
        fullscreenBtn.innerText = "❌ Exit Fullscreen";
    } else {
        if (document.exitFullscreen) {
            document.exitFullscreen();
        }
        fullscreenBtn.innerText = "⚓ Fullscreen";
    }
});

document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) {
        fullscreenBtn.innerText = "⚓ Fullscreen";
    }
});

buyShellUpgradeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    let cost = upgradeShellLevel * 10;
    if (savedShells >= cost) {
        savedShells -= cost;
        upgradeShellLevel++;
        localStorage.setItem('beach_shells', savedShells);
        localStorage.setItem('up_shell', upgradeShellLevel);
        updateShopUI();
    }
});

buyJumpUpgradeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    let cost = (upgradeJumpLevel + 1) * 15;
    if (savedShells >= cost) {
        savedShells -= cost;
        upgradeJumpLevel++;
        localStorage.setItem('beach_shells', savedShells);
        localStorage.setItem('up_jump', upgradeJumpLevel);
        updateShopUI();
    }
});

window.addEventListener('keydown', (e) => {
    if (e.code === 'Space' || e.code === 'ArrowUp') {
        if (gameActive) {
            boat.jump();
        } else {
            startGame();
        }
    }
});

canvas.addEventListener('touchstart', () => {
    if (gameActive) boat.jump();
});

startBtn.addEventListener('click', startGame);

updateShopUI();
drawEnvironment();
boat.draw();
</script>

</body>
</html>
